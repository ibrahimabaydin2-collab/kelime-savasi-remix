# Set default behavior to automatic text line ending normalization with LF
* text=auto eol=lf

# Explicitly mark binary files so Git won't perform line ending (CRLF/LF) normalization on them
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.aar binary
*.apk binary
*.aab binary
*.so binary
*.class binary
