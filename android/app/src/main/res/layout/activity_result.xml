<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Header Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DÜELLO BİTTİ!"
        android:textColor="#f8fafc"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_result_target_word"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HEDEF KELİME: -"
        android:textColor="#38bdf8"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="#1e293b" />

    <TextView
        android:id="@+id/tv_result_status_banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kazandınız, Tebrikler!"
        android:textColor="#10b981"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:visibility="visible" />

    <!-- Results Panel Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="24dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="40dp">

        <!-- Winner Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#064e3b"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 "
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_result_winner_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kazanan"
                    android:textColor="#10b981"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result_winner_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Puan"
                    android:textColor="#a7f3d0"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Loser Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#4c0519"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💀 "
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_result_loser_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kaybeden"
                    android:textColor="#f43f5e"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result_loser_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Puan"
                    android:textColor="#fecdd3"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Return to Menu Button -->
    <Button
        android:id="@+id/btn_result_back_to_menu"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="ANA MENÜYE DÖN"
        android:textColor="#0f172a"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#f59e0b"
        android:layout_marginHorizontal="12dp" />

</LinearLayout>
